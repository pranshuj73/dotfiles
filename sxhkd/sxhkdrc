### Apps, Launcher & Co.
# Terminal emulator
super + {Return,q}
  wezterm start --always-new-process

# Program launcher (dmenu and rofi)
super + {@space,d}
  rofi -show drun

# Applications
super + w
  zen

super + e
  nautilus

# reload sxhkd without restarting bspwm
super + Caps_Lock
	pkill -USR1 -x sxhkd

# restart bspwm explicitly when needed
super + alt + Caps_Lock
	bspc wm -r

# bspwm hotkeys

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + {c,shift + q}
	bspc node -{c,k}

# hypr-style minimize / restore
super + m
	sh /home/prnsh/dotfiles/sxhkd/bspwm-minimize.sh

# alternate between the tiled and monocle layout
super + ctrl + m
	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest node
super + g
	bspc node -s biggest

#
# state/flags
#

# hypr-style window states
super + t
	sh /home/prnsh/dotfiles/sxhkd/bspwm-toggle-float.sh

super + u
	bspc node -t ~pseudo_tiled

super + shift + t
	bspc node -t tiled

super + s
	bspc node -t floating

super + f
	bspc node -t ~fullscreen

# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

#
# focus/swap
#

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the node for the given path jump
super + ctrl + {p,b,comma,period}
	bspc node -f @{parent,brother,first,second}

# hypr-style pin / pip / split actions
super + p
	bspc node -g sticky

super + shift + p
	sh /home/prnsh/dotfiles/sxhkd/bspwm-pip.sh

super + alt + y
	bspc node @parent -R 90

# focus the next/previous node in the current desktop
super + {Right, Left}
	bspc node -f {next,prev}.local

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + Tab
	bspc wm -h off; \
	bspc node older -f; \
	bspc wm -h on

# cycle windows on the current desktop
alt + Tab
	bspc node -f next.local.window

alt + shift + Tab
	bspc node -f prev.local.window


# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

#
# preselect
#

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + shift + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

# Screenshots
# full screen screenshot → save + clipboard
Print
    maim  | tee ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png | xclip -selection clipboard -t image/png

# region screenshot → save + clipboard
super + shift + s
    maim -s | tee ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png | xclip -selection clipboard -t image/png

# Lock
super + F1
    i3lock-fancy-rapid 5 3

#
# Volume / Brightness / Menus
#
# Volume up
XF86AudioRaiseVolume
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+

# Volume down
XF86AudioLowerVolume
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%-

# Mute toggle
XF86AudioMute
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Mic mute
XF86AudioMicMute
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness up
XF86MonBrightnessUp
    brightnessctl set +10%

# Brightness down
XF86MonBrightnessDown
    brightnessctl set 10%-

# Play / Pause
XF86AudioPlay
    playerctl play-pause

# Stop
XF86AudioStop
    playerctl stop

# Next
XF86AudioNext
    playerctl next

# Previous
XF86AudioPrev
    playerctl previous

# clipboard menu
super + v
    CM_LAUNCHER=rofi clipmenu \
        -location 1 \
        -m -3 \
        -no-show-icons \
        -theme-str '* \{ font: 10px; \}' \
        -theme-str 'listview \{ spacing: 0; \}' \
        -theme-str 'window \{ width: 20em; \}'
